# Copy to .env or .env.docker and fill in real values.
# Do not commit real secrets.

# Prisma resolves this SQLite path relative to /app/prisma/schema.prisma inside the container.
# The host file is ./data/prisma/dev.db because docker-compose mounts ./data/prisma to /app/prisma.
DATABASE_URL=file:./dev.db

# Required. Use a random value of at least 32 characters.
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# For teammate/phone access, use the reachable LAN IP or hostname.
APP_BASE_URL=http://SERVER-IP:3000

# Optional SMTP settings. Leave blank to run beta without email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MAIL_FROM=
MAIL_REPLY_TO=
SMTP_SECURE=false
IT_NOTIFICATION_CC=
IT_ASSIGNMENT_CC=
IT_LOAN_CC=
IT_RMA_CC=
IT_STOCK_CC=
