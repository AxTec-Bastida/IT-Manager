model Device {
  id                            String                       @id @default(cuid())
  assetTag                      String?                      @unique
  name                          String
  category                      DeviceCategory
  ipAddress                     String?
  macAddress                    String?
  vlan                          Int?
  location                      String?
  areaDepartment                String?
  brand                         String?
  model                         String?
  serialNumber                  String?
  status                        DeviceStatus                 @default(ACTIVE)
  condition                     DeviceCondition              @default(GOOD)
  assignedTo                    String?
  employeeId                    String?
  employee                      Employee?                    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  purchaseDate                  DateTime?
  warrantyExpiresAt             DateTime?
  repairNotes                   String?
  blackTonerLevel               Int?
  cyanTonerLevel                Int?
  magentaTonerLevel             Int?
  yellowTonerLevel              Int?
  drumLevel                     Int?
  fuserStatus                   String?
  pageCount                     Int?
  lastSupplyReplacementAt       DateTime?
  lowSupplyThreshold            Int?
  lastCleanedAt                 DateTime?
  cleaningIntervalDays          Int?
  lastPrintheadReplacementAt    DateTime?
  lastPlatenRollerReplacementAt DateTime?
  lastCutterReplacementAt       DateTime?
  estimatedPrintheadLife        Int?
  maintenanceDueAt              DateTime?
  maintenanceNotes              String?
  notes                         String?
  lastSeenAt                    DateTime?
  facturaId                     String?
  factura                       Factura?                     @relation(fields: [facturaId], references: [id], onDelete: SetNull)
  isFixedAsset                  Boolean                      @default(false)
  usesStaticIp                  Boolean                      @default(false)
  expectedLocationZoneId        String?
  expectedLocationZone          LocationZone?                @relation(fields: [expectedLocationZoneId], references: [id], onDelete: SetNull)
  movementAlertsEnabled         Boolean                      @default(false)
  allowedZoneDistance           Int                          @default(0)
  currentMapAnchorId            String?
  currentMapAnchor              AccessPointMapLocation?      @relation("DeviceCurrentMapAnchor", fields: [currentMapAnchorId], references: [id], onDelete: SetNull)
  ipRangeId                     String?
  ipRange                       IpRange?                     @relation(fields: [ipRangeId], references: [id], onDelete: SetNull)
  photos                        AssetPhoto[]
  locationHistory               AssetLocationHistory[]
  unifiSnapshots                UnifiClientSnapshot[]
  assignmentItems               AssignmentItem[]
  maintenanceRecords            MaintenanceRecord[]
  stockMovements                StockMovement[]
  alerts                        Alert[]
  tasks                         Task[]
  purchaseNoteItems             PurchaseNoteItem[]
  rmaItems                      RmaItem[]                    @relation("RmaItemDevice")
  replacementForRmaItems        RmaItem[]                    @relation("RmaItemReplacementDevice")
  assetLoanItems                AssetLoanItem[]
  emailLogs                     EmailLog[]
  aliases                       DeviceAlias[]
  sourceRelationships           DeviceRelationship[]         @relation("DeviceRelationshipSource")
  targetRelationships           DeviceRelationship[]         @relation("DeviceRelationshipTarget")
  auditExpectedItems            InventoryAuditExpectedItem[]
  auditScans                    InventoryAuditScan[]
  decommissionRecords           AssetDecommissionRecord[]
  valueProfile                  AssetValueProfile?
  facturaLineItemLinks          FacturaLineItemAsset[]
  bitLockerRecoveryKey          BitLockerRecoveryKey?
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt

  @@index([ipAddress])
  @@index([macAddress])
  @@index([assetTag])
  @@index([serialNumber])
  @@index([category])
  @@index([status])
  @@index([condition])
  @@index([employeeId])
  @@index([facturaId])
  @@index([expectedLocationZoneId])
  @@index([currentMapAnchorId])
  @@index([vlan])
}

model AssetDecommissionRecord {
  id                           String                  @id @default(cuid())
  deviceId                     String
  device                       Device                  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  reason                       AssetDecommissionReason
  finalStatus                  DeviceStatus
  checklistJson                String?
  notes                        String?
  estimatedValueAtDecommission Float?
  estimatedValueCurrency       String?
  approvedByUserId             String?
  approvedByName               String?
  performedByUserId            String?
  performedByName              String?
  performedAt                  DateTime                @default(now())
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt

  @@index([deviceId])
  @@index([reason])
  @@index([finalStatus])
  @@index([performedAt])
  @@index([performedByUserId])
}

model AssetValueProfile {
  id                           String                @id @default(cuid())
  deviceId                     String                @unique
  device                       Device                @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  purchaseValue                Float?
  currency                     String                @default("MXN")
  purchaseDate                 DateTime?
  depreciationMethod           DepreciationMethod    @default(STRAIGHT_LINE)
  usefulLifeMonths             Int?
  residualPercent              Float                 @default(30)
  residualValue                Float?
  currentEstimatedValue        Float?
  lastCalculatedAt             DateTime?
  notes                        String?
  sourceType                   String?
  sourceFacturaLineItemAssetId String?
  sourceFacturaLineItemAsset   FacturaLineItemAsset? @relation(fields: [sourceFacturaLineItemAssetId], references: [id], onDelete: SetNull)
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt

  @@index([currency])
  @@index([purchaseDate])
  @@index([sourceType])
  @@index([sourceFacturaLineItemAssetId])
}

model BitLockerRecoveryKey {
  id                   String    @id @default(cuid())
  deviceId             String    @unique
  device               Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  recoveryKeyEncrypted String
  keyId                String?
  volumeLabel          String?
  protectorId          String?
  source               String    @default("MANUAL")
  notes                String?
  createdByUserId      String
  createdByName        String
  updatedByUserId      String?
  updatedByName        String?
  lastViewedAt         DateTime?
  lastViewedByUserId   String?
  lastViewedByName     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([keyId])
  @@index([lastViewedAt])
  @@index([createdAt])
}

model DeviceAlias {
  id           String          @id @default(cuid())
  deviceId     String
  device       Device          @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  aliasType    DeviceAliasType
  value        String
  sourceSheet  String?
  sourceColumn String?
  sourceRow    Int?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([deviceId, aliasType, value])
  @@index([deviceId])
  @@index([aliasType])
  @@index([value])
  @@index([sourceSheet, sourceRow])
}

model DeviceRelationship {
  id               String                   @id @default(cuid())
  sourceDeviceId   String
  sourceDevice     Device                   @relation("DeviceRelationshipSource", fields: [sourceDeviceId], references: [id], onDelete: Cascade)
  targetDeviceId   String
  targetDevice     Device                   @relation("DeviceRelationshipTarget", fields: [targetDeviceId], references: [id], onDelete: Cascade)
  relationshipType DeviceRelationshipType
  status           DeviceRelationshipStatus @default(ACTIVE)
  sourceReference  String?
  confidence       Float?
  notes            String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([sourceDeviceId, targetDeviceId, relationshipType])
  @@index([sourceDeviceId])
  @@index([targetDeviceId])
  @@index([relationshipType])
  @@index([status])
}

model LocationZone {
  id             String                   @id @default(cuid())
  name           String
  description    String?
  floorName      String?
  color          String?
  active         Boolean                  @default(true)
  mapId          String?
  map            WarehouseMap?            @relation(fields: [mapId], references: [id], onDelete: SetNull)
  accessPoints   AccessPointMapLocation[]
  expectedAssets Device[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([name])
  @@index([active])
  @@index([mapId])
}

model AssetPhoto {
  id                 String         @id @default(cuid())
  assetId            String
  asset              Device         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  photoType          AssetPhotoType @default(OTHER)
  caption            String?
  originalFilename   String?
  storedFilename     String
  filePath           String
  mimeType           String
  fileSize           Int
  sizeBytes          Int?
  width              Int?
  height             Int?
  thumbnailFilename  String?
  thumbnailPath      String?
  optimizedFilename  String?
  optimizedPath      String?
  uploadedByUserId   String?
  uploadedByUser     AppUser?       @relation("AssetPhotoUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  uploadedByName     String?
  compressionApplied Boolean        @default(false)
  source             PhotoSource    @default(UNKNOWN)
  isPrimary          Boolean        @default(false)
  uploadedBy         String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([assetId])
  @@index([photoType])
  @@index([isPrimary])
  @@index([uploadedByUserId])
  @@index([source])
}

model Factura {
  id                 String                     @id @default(cuid())
  facturaNumber      String
  vendorName         String
  vendorRfc          String?
  purchaseDate       DateTime?
  receivedDate       DateTime?
  poNumber           String?
  totalAmount        Float?
  currency           String                     @default("USD")
  warrantyStartAt    DateTime?
  warrantyEndAt      DateTime?
  notes              String?
  originalFilename   String?
  storedFilename     String?
  filePath           String?
  mimeType           String?
  fileSize           Int?
  xmlPath            String?
  xmlFilename        String?
  xmlOriginalName    String?
  xmlMimeType        String?
  xmlSizeBytes       Int?
  xmlUploadedAt      DateTime?
  xmlUuid            String?
  xmlSerie           String?
  xmlFolio           String?
  xmlIssuedAt        DateTime?
  xmlCurrency        String?
  xmlSubtotal        Float?
  xmlTotal           Float?
  xmlEmisorName      String?
  xmlEmisorRfc       String?
  assets             Device[]
  stockItems         StockItem[]
  stockMovements     StockMovement[]
  lineItems          FacturaLineItem[]
  extractionAttempts FacturaExtractionAttempt[]
  tasks              Task[]
  purchaseNotes      PurchaseNote[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([facturaNumber])
  @@index([vendorName])
  @@index([poNumber])
  @@index([purchaseDate])
}

model FacturaLineItem {
  id          String                 @id @default(cuid())
  facturaId   String
  factura     Factura                @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  description String
  sku         String?
  model       String?
  category    DeviceCategory?
  quantity    Int
  unitCost    Float
  currency    String                 @default("MXN")
  totalCost   Float
  notes       String?
  assetLinks  FacturaLineItemAsset[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([facturaId])
  @@index([category])
  @@index([sku])
  @@index([model])
}

model FacturaExtractionAttempt {
  id                   String   @id @default(cuid())
  facturaId            String
  factura              Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  status               String
  candidateCount       Int      @default(0)
  createdLineItemCount Int      @default(0)
  warningsJson         String?
  performedByUserId    String?
  performedByUser      AppUser? @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)
  performedByName      String?
  createdAt            DateTime @default(now())

  @@index([facturaId])
  @@index([status])
  @@index([performedByUserId])
  @@index([createdAt])
}

model FacturaLineItemAsset {
  id                String              @id @default(cuid())
  facturaLineItemId String
  lineItem          FacturaLineItem     @relation(fields: [facturaLineItemId], references: [id], onDelete: Cascade)
  deviceId          String
  device            Device              @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  allocatedUnitCost Float?
  currency          String              @default("MXN")
  notes             String?
  valueProfiles     AssetValueProfile[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([facturaLineItemId, deviceId])
  @@index([facturaLineItemId])
  @@index([deviceId])
}

model StockItem {
  id                      String              @id @default(cuid())
  name                    String
  sku                     String?             @unique
  barcodeValue            String?             @unique
  category                StockCategory
  itemType                StockItemType
  compatibleAssetCategory DeviceCategory?
  compatibleModels        String?
  quantityOnHand          Int                 @default(0)
  minimumQuantity         Int                 @default(0)
  reorderQuantity         Int?
  unitCost                Float?
  currency                String?             @default("USD")
  vendorName              String?
  storageLocation         String?
  notes                   String?
  active                  Boolean             @default(true)
  facturaId               String?
  factura                 Factura?            @relation(fields: [facturaId], references: [id], onDelete: SetNull)
  movements               StockMovement[]
  photos                  StockItemPhoto[]
  stockIssues             StockIssue[]
  maintenanceRecords      MaintenanceRecord[]
  alerts                  Alert[]
  tasks                   Task[]
  purchaseNoteItems       PurchaseNoteItem[]
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([name])
  @@index([sku])
  @@index([barcodeValue])
  @@index([category])
  @@index([itemType])
  @@index([facturaId])
  @@index([active])
}

model StockItemPhoto {
  id                String             @id @default(cuid())
  stockItemId       String
  stockItem         StockItem          @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  photoType         StockItemPhotoType @default(OTHER)
  caption           String?
  originalFilename  String?
  storedFilename    String
  filePath          String
  mimeType          String
  sizeBytes         Int
  width             Int?
  height            Int?
  thumbnailFilename String?
  thumbnailPath     String?
  uploadedByUserId  String?
  uploadedByUser    AppUser?           @relation("StockItemPhotoUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  uploadedByName    String?
  source            PhotoSource        @default(UNKNOWN)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([stockItemId])
  @@index([photoType])
  @@index([uploadedByUserId])
}

model StockMovement {
  id                  String             @id @default(cuid())
  stockItemId         String
  stockItem           StockItem          @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  assetId             String?
  asset               Device?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
