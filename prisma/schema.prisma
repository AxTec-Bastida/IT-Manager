  scheduleId   String?
  schedule     ScheduledJob?    @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  type         ScheduledJobType
  startedAt    DateTime
  finishedAt   DateTime?
  status       JobRunStatus
  summaryJson  String?
  errorMessage String?
  createdAt    DateTime         @default(now())

  @@index([scheduleId])
  @@index([type])
  @@index([status])
  @@index([startedAt])
}

model OfflineSyncRecord {
  id               String                  @id @default(cuid())
  clientActionId   String                  @unique
  actionType       OfflineActionType
  status           OfflineSyncStatus
  resolutionStatus OfflineResolutionStatus @default(OPEN)
  actorUserId      String?
  actorUser        AppUser?                @relation("OfflineSyncRecordActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorName        String?
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewedByUser   AppUser?                @relation("OfflineSyncRecordReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reviewNote       String?
  conflictCode     String?
  entityType       String?
  entityId         String?
  entityLabel      String?
  payloadSummary   String?
  resultSummary    String?
  createdAt        DateTime                @default(now())
  processedAt      DateTime?

  @@index([actionType])
  @@index([status])
  @@index([resolutionStatus])
  @@index([actorUserId])
  @@index([reviewedByUserId])
  @@index([conflictCode])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([processedAt])
}

model EmailLog {
  id              String         @id @default(cuid())
  type            EmailLogType
  recipient       String
  cc              String?
  subject         String
  status          EmailLogStatus
  errorMessage    String?
  messageId       String?
  relatedDeviceId String?
  relatedDevice   Device?        @relation(fields: [relatedDeviceId], references: [id], onDelete: SetNull)
  assignmentId    String?
  assignment      Assignment?    @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  assetLoanId     String?
  assetLoan       AssetLoan?     @relation(fields: [assetLoanId], references: [id], onDelete: SetNull)
  stockIssueId    String?
  stockIssue      StockIssue?    @relation(fields: [stockIssueId], references: [id], onDelete: SetNull)
  rmaCaseId       String?
  rmaCase         RmaCase?       @relation(fields: [rmaCaseId], references: [id], onDelete: SetNull)
  alertId         String?
  alert           Alert?         @relation(fields: [alertId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([type])
  @@index([status])
  @@index([recipient])
  @@index([relatedDeviceId])
  @@index([assignmentId])
  @@index([assetLoanId])
  @@index([stockIssueId])
  @@index([rmaCaseId])
  @@index([alertId])
  @@index([createdAt])
}

model AppSettings {
  id                                 String         @id @default("default")
  defaultVlan                        Int            @default(10)
  defaultCategory                    DeviceCategory @default(OTHER)
  maxScanSize                        Int            @default(64)
  pingTimeoutMs                      Int            @default(800)
  autoSaveScanResults                Boolean        @default(true)
  siteName                           String         @default("Warehouse IT Inventory")
  defaultLowStockThreshold           Int            @default(2)
  defaultThermalCleaningIntervalDays Int            @default(30)
  defaultMfpLowSupplyThreshold       Int            @default(20)
  enablePrinterMaintenanceAlerts     Boolean        @default(true)
  enableLowStockAlerts               Boolean        @default(true)
  enableConflictAlerts               Boolean        @default(true)
  enableWarrantyAlerts               Boolean        @default(true)
  warrantyAlertThresholdDays         Int            @default(60)
  enableMovementAlerts               Boolean        @default(true)
  defaultAllowedZoneDistance         Int            @default(0)
  autoResolveMovementAlerts          Boolean        @default(false)
  enableMissingAssetSeenOnlineAlerts Boolean        @default(true)
  alertDuplicateSuppressionEnabled   Boolean        @default(true)
  defaultCurrency                    String         @default("USD")
  autoSendAssignmentReceipts         Boolean        @default(false)
  autoSendAssetLoanReceipts          Boolean        @default(false)
  autoSendStockIssueReceipts         Boolean        @default(false)
  autoSendRmaEmails                  Boolean        @default(false)
  autoSendReturnConfirmations        Boolean        @default(false)
  autoSendOverdueReminderEmails      Boolean        @default(false)
  createdAt                          DateTime       @default(now())
  updatedAt                          DateTime       @updatedAt
}
